# GTRobot .env fayli
# Bu faylni to'ldiring va .env deb saqlang

# Telegram Bot Token (@BotFather dan oling)
BOT_TOKEN=7123456789:AABBCCDDEEFFaabbccddeeff1234567890

# Admin Telegram ID lari (vergul bilan ajrating)
# ID ni @userinfobot dan bilib olishingiz mumkin
ADMIN_IDS=123456789,987654321

# Majburiy obuna kanali
# Kanal username: @kanal_nomi
# Yoki kanal ID: -1001234567890
REQUIRED_CHANNEL=@your_channel
